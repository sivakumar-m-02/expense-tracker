{
  "name": "ExpenseTracker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-CimInstance Win32_Process -Filter \\\"Name='node.exe'\\\" | ? { $_.CommandLine -match 'mini-instagram|react-native|metro' } | % { Stop-Process -Id $_.ProcessId -Force }; Set-Location android; .\\\\gradlew.bat --stop; if (Test-Path app\\\\build) { Remove-Item app\\\\build -Recurse -Force }; Set-Location ..; npx react-native start --reset-cache\"",
    "android:fresh-build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Set-Location android; .\\\\gradlew.bat clean; Set-Location ..; npx react-native run-android --no-packager\"",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start --reset-cache",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-firebase/app": "^23.1.0",
    "@react-native-firebase/auth": "^23.1.0",
    "@react-native-firebase/firestore": "^23.1.0",
    "@react-native-firebase/storage": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "axios": "^1.15.0",
    "lottie-react-native": "^7.3.6",
    "moment": "^2.30.1",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "3.19.5",
    "react-native-responsive-fontsize": "^0.5.1",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "4.14.1",
    "react-native-svg": "^15.12.1",
